{
  "name": "@otl-core/script-utils",
  "version": "1.1.11",
  "type": "module",
  "description": "Script rendering and event mapping utilities for OTL CMS",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "clean": "rm -rf dist",
    "rebuild": "npm run clean && npm run build",
    "test": "vitest run"
  },
  "keywords": [
    "script",
    "analytics",
    "event-mapping",
    "typescript",
    "cms"
  ],
  "author": "OTL Core",
  "license": "PolyForm-Shield-1.0.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/otl-core/script-utils.git"
  },
  "dependencies": {
    "@otl-core/cms-types": "^1.1.11"
  },
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^5.0.0",
    "vitest": "^4.0.0"
  }
}
